<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LawPortal - Argentina</title>
    <link rel="icon" href="/img/Logo.ico" type="image/x-icon">
    <meta name="description"
        content="Portal de redireccionamiento que ofrece enlaces directos a normativas legales y otros sitios importantes. Filtra fácilmente y accede rápidamente a la información que necesitas.">
    <meta name="keywords"
        content="redireccionamiento, normativas, leyes, portal, búsqueda, enlaces, gobierno, Argentina">
    <meta name="author" content="Franco Calegari">
    <meta property="og:title" content="LawPortal">
    <meta property="og:description"
        content="Accede fácilmente a normativas legales y otros sitios importantes a través de nuestro portal de redireccionamiento.">
    <meta property="og:type" content="website">
    <meta property="og:image" content="/img/LawPortalv1.jpg">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Portal de Redireccionamiento">
    <meta name="twitter:site" content="@FrancoCalegari19">
    <meta name="theme-color" content="#7ff8fe">
    <link rel="manifest" href="/manifest.json">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Platypi:ital,wght@0,300..800;1,300..800&family=Quicksand:wght@300..700&family=Rubik:ital,wght@0,300..900;1,300..900&display=swap"
        rel="stylesheet">
    <script src="https://kit.fontawesome.com/274f77f0e3.js" crossorigin="anonymous"></script>
    <script id="chatBroEmbedCode">
        function ChatbroLoader(chats, async) { async = !1 !== async; var params = { embedChatsParameters: chats instanceof Array ? chats : [chats], lang: navigator.language || navigator.userLanguage, needLoadCode: 'undefined' == typeof Chatbro, embedParamsVersion: localStorage.embedParamsVersion, chatbroScriptVersion: localStorage.chatbroScriptVersion }, xhr = new XMLHttpRequest; xhr.withCredentials = !0, xhr.onload = function () { eval(xhr.responseText) }, xhr.onerror = function () { console.error('Chatbro loading error') }, xhr.open('GET', 'https://www.chatbro.com/embed.js?' + btoa(unescape(encodeURIComponent(JSON.stringify(params)))), async), xhr.send() }
        ChatbroLoader({ encodedChatId: '28zG1' });
    </script>
</head>

<body>

    <div class="background">
        <img src="/img/fondo.png" alt="Fondo difuminado">
    </div>

    <div id="preloader">
        <div class="book">
            <div class="cover"></div>
            <div class="pages"></div>
            <div class="back"></div>
        </div>
    </div>

    <main>
        <section class="container">
            <div class="titlecontainer">
                <div class="hero-badge">
                    <i class="fa-solid fa-scale-balanced"></i>
                    Portal Legal Argentino
                </div>
                <h1>LawPortal <span class="title-accent">Argentina</span></h1>
            </div>

            <p class="hero-subtitle">Accedé rápidamente a toda la normativa legal nacional, provincial e internacional.
            </p>

            <% if (error) { %>
                <div class="alert alert-error">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <%= error %>
                </div>
                <% } %>

                    <div class="search-wrapper">
                        <i class="fa-solid fa-magnifying-glass search-icon"></i>
                        <input type="text" id="searchBar" placeholder="Buscar por título...">
                    </div>

                    <div id="category-buttons"></div>

                    <div id="card-grid" class="card-grid">
                        <% codes.forEach(function(code) { %>
                            <div class="card" data-jurisdiction="<%= code.jurisdiction %>"
                                data-title="<%= code.title.toLowerCase() %>">
                                <div class="card-img-wrapper" onclick="window.open('<%= code.link %>', '_blank')">
                                    <img src="<%= code.image_url %>" alt="<%= code.title %>"
                                        onerror="this.src='/img/portadas/default.webp'; this.onerror=null;">
                                    <div class="card-img-overlay">
                                        <i class="fa-solid fa-arrow-up-right-from-square"></i>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="card-jurisdiction">
                                        <span class="badge badge-<%= code.jurisdiction.toLowerCase() %>">
                                            <%= code.jurisdiction %>
                                        </span>
                                    </div>
                                    <div class="card-title">
                                        <%= code.title %>
                                    </div>
                                    <div class="card-buttons">
                                        <% if (code.pdf && code.pdf.trim() !=='' ) { %>
                                            <a href="<%= code.pdf %>" target="_blank" class="btn-card btn-pdf">
                                                <i class="fa-solid fa-file-pdf"></i> PDF
                                            </a>
                                            <% } %>
                                                <% if (code.coment && code.coment.trim() !=='' ) { %>
                                                    <a href="<%= code.coment %>" target="_blank"
                                                        class="btn-card btn-coment">
                                                        <i class="fa-solid fa-comments"></i> Comentado
                                                    </a>
                                                    <% } %>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                                <% if (codes.length===0 && !error) { %>
                                    <p class="no-results"><i class="fa-solid fa-inbox"></i> No hay códigos cargados
                                        todavía.</p>
                                    <% } %>
                    </div>
        </section>

        <section id="about">
            <h2><i class="fa-solid fa-circle-info"></i> Sobre LawPortal</h2>
            <p>LawPortal es una web diseñada para ayudarte a encontrar el material más rápido que cualquier otra
                plataforma, permitiéndote descargar archivos PDF o revisar los comentarios de abogados sobre las leyes.
            </p>
            <p>Si tienes sugerencias de cambios o cosas para agregar, no dudes en enviarnos un mensaje: <a
                    href="mailto:francocalegari55@gmail.com">francocalegari55@gmail.com</a>.</p>
            <a href='https://cafecito.app/francocalegaridev' rel='noopener' target='_blank'>
                <img srcset='https://cdn.cafecito.app/imgs/buttons/button_6.png 1x, https://cdn.cafecito.app/imgs/buttons/button_6_2x.png 2x'
                    src='https://cdn.cafecito.app/imgs/buttons/button_6.png' alt='Invitame un café en cafecito.app'>
            </a>
        </section>
    </main>

    <footer>
        <div class="contactContainer">
            <div class="socialMediaContainer">
                <div class="socialMedia">
                    <a href="https://www.facebook.com/" target="_blank"><i class="fa-brands fa-facebook"></i></a>
                    <a href="https://www.threads.com/" target="_blank"><i class="fa-brands fa-square-x-twitter"></i></a>
                    <a href="https://www.instagram.com/" target="_blank"><i class="fa-brands fa-instagram"></i></a>
                </div>
                <div class="logo">
                    <img src="/img/Logo.png" alt="Law-Portal" style="height: 80px;">
                </div>
                <div class="socialMedia">
                    <a href="https://www.youtube.com" target="_blank"><i class="fa-brands fa-youtube"></i></a>
                    <a href="https://discord.gg" target="_blank"><i class="fa-brands fa-discord"></i></a>
                    <a href="https://www.whatsapp.com" target="_blank"><i class="fa-brands fa-whatsapp"></i></a>
                </div>
            </div>
        </div>
        <p>&copy; 2025 Law-Portal v1.0 — Todos los derechos reservados.</p>
        <div class="footer-credit">
            <a href="https://francocalegari.github.io/PortfolioFrancoCalegari/" target="_blank">Code by Franco
                Calegari</a>
        </div>
    </footer>

    <script src="/js/main.js"></script>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PVVN74LFGE"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-PVVN74LFGE');
    </script>
</body>

</html>